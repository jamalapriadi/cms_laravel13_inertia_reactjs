{
  "name": "starter-creative-theme",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:css\" \"npm:dev:js\"",
    "dev:css": "tailwindcss -i ./css/input.css -o ../public/css/output.css --watch",
    "dev:js": "vite --config vite.config.js --host 0.0.0.0",
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i ./css/input.css -o ../public/css/output.css --minify",
    "build:js": "vite build --config vite.config.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "concurrently": "^9.0.1",
    "tailwindcss": "^4.0.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "gsap": "^3.13.0",
    "swiper": "^12.1.2"
  }
}
