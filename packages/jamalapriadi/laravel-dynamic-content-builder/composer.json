{
    "name": "jamalapriadi/laravel-dynamic-content-builder",
    "description": "Dynamic Content Builder package for Laravel + Inertia + React projects.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/framework": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Jamalapriadi\\DynamicContentBuilder\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jamalapriadi\\DynamicContentBuilder\\DynamicContentBuilderServiceProvider"
            ]
        }
    }
}
